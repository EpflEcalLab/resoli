{% import "@quartiers_solidaires/macros.html.twig" as macros %}

<a
  data-toggle="collapse"
  href="#collapse-{{ event.nid.value }}"
  class="card-pill card-pill-simple collapsed"
  role="tab"
  aria-expanded="false"
  aria-controls="collapse-{{ event.nid.value }}"
  id="event{{ event.nid.value }}"
>

  <span class="card-pill-icon card-pill-icon-lg">
    {{ macros.icon('theme_' ~ event.field_activity.entity.field_theme.entity.field_icon.value) }}
  </span>

  <span class="card-pill-title">
    <span class="lead">
      {{ event.field_activity.entity.title.value }}
    </span>
  </span>

  {% block card_pill_badges %}
    {# Subscription Badges #}
    {% include '@quartiers_solidaires/qs_badge/partials/qs--badge--subscription.html.twig' with {'event': event, 'badges': variables.badges} %}
  {% endblock %}

  <span class="size-date text-dark">
    {% block card_pill_time %}
    <time datetime="{{ event.field_start_at.date|date('Y-m-d') }}">
      {{ event.field_start_at.date|bamboo_i18n_format_date('default_medium_date_only_no_year') }}
      <span class="d-none d-md-inline-block d-lg-inline-block d-xl-inline-block">{{ event.field_start_at.date|date('Y') }}</span>
    </time>
    {% endblock %}
  </span>

  <span
    class="btn btn-outline-secondary btn-circle shadow-to-left btn-white ml-1"
    aria-label="{{ 'qs.readmore.about'|t }} {{ event.label }}"
  >
    {{ macros.icon('look') }}
    <span class="sr-only d-none d-md-inline">{{ 'qs.event.more'|t }}</span>
  </span>
</a>

