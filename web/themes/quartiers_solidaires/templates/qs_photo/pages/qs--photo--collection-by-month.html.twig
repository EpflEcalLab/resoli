{% import "@quartiers_solidaires/macros.html.twig" as macros %}
{% set community_name = variables.community.name.value|trim %}

{% if variables.photos %}
  <div class="container">
    <p class="lead text-center mt-5">
      {{ 'qs.photo.month.lead @community @month @year'|t({
        '@month': variables.dates.start|bamboo_i18n_format_date('custom', 'F'),
        '@year': variables.dates.start|date('Y'),
        '@community': community_name,
      }) }}
    </p>
  </div>
{% else %}
  <div class="container">
    <p class="lead text-center mt-5">
      {{ 'qs.photo.month.empty @community @month @year'|t({
        '@month': variables.dates.start|bamboo_i18n_format_date('custom', 'F'),
        '@year': variables.dates.start|date('Y'),
        '@community': community_name,
      }) }}
    </p>
  </div>
{% endif %}

{{ bamboo_render_block('qs_photo_monthly_block') }}

{% if variables.photos %}
  <div class="container my-5">
    <div class="row gallery-photoswipe" data-pswp-uid="gallery">
      {% set current_header = null %}

      {% for key, photo in variables.photos %}

        {% set date = photo.field_event.entity.field_start_at.value|date('Y-m-d') %}
        {% set week = photo.field_event.entity.field_start_at.value|date('W') %}
        {% set current_week = 'now'|date('W') %}

        {% set new_header = 'qs.photos.date.sticky.from_to @start_date @end_date'|t({
          '@start_date': date|date_modify("this week")|date('j F Y'),
          '@end_date': date|date_modify("this week +6 days")|date('j F Y')
        }) %}

        {% if 'now'|date('Y-m-d') == date %}
          {# TODAY #}
          {% set new_header = 'qs.photos.date.sticky.today'|t %}

        {% elseif 'yesterday'|date('Y-m-d') == date %}
          {# YESTERDAY #}
          {% set new_header = 'qs.photos.date.sticky.tomorrow'|t %}

        {% elseif date < 'yesterday'|date('Y-m-d') and current_week == week %}
          {# THIS WEEK (between day before yesterday and previous Sunday but not last week) #}
          {% set new_header = 'qs.photos.date.sticky.this_week'|t %}

        {% elseif current_week != week %}
          {# PREVIOUS WEEKS #}
          {% set week_diff = current_week - week %}
          {% if week_diff == 1 %}
            {% set new_header = 'qs.photos.date.sticky.last_week'|t %}
          {% elseif week_diff == 2 %}
            {% set new_header = 'qs.photos.date.sticky.two_weeks_ago'|t %}
          {% endif %}
        {% endif %}

        {# Write the header if we have a new value #}
        {% if current_header|render != new_header|render %}
          {% set current_header = new_header %}

          {% if loop.index > 1 %}
          {# Close the previous card list #}
            </div>
          {% endif %}

          <div class="col-12 sticky-top bg-white mb-3">
            <h2 class="col-12 h5 mb-0">{{ current_header }}</h2>
          </div>
          <div class="row col-12 flex-row">
        {% endif %}

        <div class="col-6 col-sm-4 col-md-3 d-flex mb-3">
          <figure
            class="gallery-item"
          >
            {% set image_width = photo.field_image.width %}
            {% set image_height = photo.field_image.height %}
            <a
              href="{{ path('qs_photo.streamer', {'photo': photo.nid.value, 'image_style': 'gallery_fullsize'}) }}"
              class="card"
              data-index="{{ loop.index }}"
              data-size="{{ image_width > 1920 ? 1920 : image_width }}x{{ image_height > 1080 ? 1080 : image_height }}"
            >
              <img class="card-img" src="{{ path('qs_photo.streamer', {'photo': photo.nid.value, 'image_style': 'qs_thumbnail'}) }}" alt="{{ photo.title.value }}" title="{{ photo.title.value }}">
              <span class="btn btn-outline-secondary btn-circle card-btn-corner bg-white">
                {{ macros.icon('look') }}
              </span>
            </a>
            {% include '@quartiers_solidaires/qs_photo/pages/partials/photo-gallery-card.html.twig' %}
          </figure>
        </div>
      {% endfor %}
      {# Close the last card list #}
      </div>
    </div>

  </div>

  {% include '@quartiers_solidaires/misc/photoswipe-wrapper.html.twig' %}
{% endif %}
