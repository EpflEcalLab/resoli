{#
/**
 * @file
 * Theme override for an 'input' #type form element.
 *
 * Available variables:
 * - attributes: A list of HTML attributes for the input element.
 * - children: Optional additional rendered elements.
 *
 * @see template_preprocess_input()
 */
#}
{% import '@quartiers_solidaires/macros.html.twig' as macros %}
{% set classes = [
  'custom-control-input',
] %}
<div class="mb-3">
  <label class="checkbox-image card" for="{{ attributes.id }}">
    <input{{ attributes.addClass(classes) }} />
    <span class="checkbox-image-overlay"></span>
    {{ macros.icon('check') }}
    <img class="card-img" src="{{ path('qs_photo.streamer', {'photo': element['#return_value'], 'image_style': 'qs_thumbnail'}) }}" alt="{{ element['#title'] }}">
  </label>
</div>
