{
    "_comment": [
      "behat/gherkin to be upgrade - 3.4.0 breaks the ability to run individual tests -> https://github.com/Behat/Behat/issues/1076"
    ],
    "name": "drupal-composer/drupal-project",
    "description": "Project template for Drupal 8 projects with composer",
    "type": "project",
    "license": "GPL-2.0+",
    "authors": [
        {
            "name": "Antistatique SA",
            "role": "Development Agency"
        },
        {
            "name": "Kevin Wenger",
            "role": "FullStack Developer at Antistatique SA"
        },
        {
            "name": "Toni Fisler",
            "role": "Frontend Developer at Antistatique SA"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^1.2",
        "cweagans/composer-patches": "^1.6",
        "drupal-composer/drupal-scaffold": "^2.2",
        "drupal/admin_toolbar": "^1.19",
        "drupal/allowed_formats": "^1.1",
        "drupal/backerymails": "^1.2",
        "drupal/bamboo_twig": "^3.0",
        "drupal/block_exclude_pages": "^1.2",
        "drupal/console": "^1.0.2",
        "drupal/core": "~8.0",
        "drupal/field_group": "^1.0@RC",
        "drupal/focal_point": "^1.0@beta",
        "drupal/honeypot": "^1.27",
        "drupal/image_effects": "^2.1",
        "drupal/mailsystem": "^4.1",
        "drupal/masquerade": "^2.0@beta",
        "drupal/metatag": "^1.1",
        "drupal/pathauto": "^1.0",
        "drupal/redirect": "^1.0@beta",
        "drupal/swiftmailer": "^1.0@beta",
        "drush/drush": "^9.0.0",
        "ralouphie/mimey": "^2.0",
        "symfony/property-access": "^3.3",
        "webflo/drupal-finder": "^1.0.0",
        "webmozart/path-util": "^2.3"
    },
    "require-dev": {
        "alexandresalome/mailcatcher": "^1.2",
        "behat/behat": "~3.3.0",
        "behat/gherkin": "4.4.5",
        "drupal/default_content": "^1.0@alpha",
        "drupal/devel": "^1.0",
        "drupal/drupal-extension": "^3.4",
        "phpmd/phpmd": "^2.6",
        "sebastian/phpcpd": "^2.0",
        "squizlabs/php_codesniffer": "^2.7",
        "wapmorgan/php-code-fixer": "^2.0",
        "webflo/drupal-core-require-dev": "^8.6.1"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
      "sort-packages": true
    },
    "autoload": {
        "classmap": [
            "scripts/composer/ScriptHandler.php"
        ]
    },
    "autoload-dev": {
      "psr-4": {
          "Drupal\\Behat\\": "behat"
      }
    },
    "scripts": {
        "drupal-scaffold": "DrupalComposer\\DrupalScaffold\\Plugin::scaffold",
        "pre-install-cmd": [
            "DrupalProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "pre-update-cmd": [
            "DrupalProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "post-install-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles"
        ],
        "post-update-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles"
        ]
    },
    "extra": {
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/contrib/{$name}": ["type:drupal-drush"]
        },
        "patches": {
          "drupal/core": {
            "Updating Drupal 8.6.x to twig 1.40.0 causes twig exceptions - https://www.drupal.org/project/drupal/issues/3051269": "https://www.drupal.org/files/issues/2019-04-29/3051269-45_0.patch",
            "Updating twig/twig to v1.38.2 (included in Drupal 8.6.11) causes fatal error when embed tags are used in templates - https://www.drupal.org/project/drupal/issues/3040210": "https://www.drupal.org/files/issues/2019-03-14/3040210-PASS.patch"

          }
        }
    }
}
