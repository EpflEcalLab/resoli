<div class="container">
  <div class="row">
    <div class="col-sm-10 col-lg-8 mx-auto text-center">
      <h2>{% trans %}qs.auth.communities.dashboard_title {{ variables.community.name.value }}{% endtrans %}</h2>
      <p>{{ 'qs.auth.communities.dashboard_description'|t }}</p>
    </div>
  </div>
  <div class="row">
    <div class="col-sm-8 col-md-6 mx-auto">
      <ul class="list-unstyled mt-3">
        <li>
          <a class="btn btn-outline-secondary btn-block shadow-to-bottom mb-2" href="{{ path('qs_community.members', {community: variables.community.tid.value}) }}">
            {% trans %}qs_community.dashboard.members{% endtrans %}
          </a>
        </li>
        <li>
          <a class="btn btn-outline-secondary btn-block shadow-to-bottom mb-2" href="{{ path('qs_community.waiting_approval', {community: variables.community.tid.value}) }}">
            {% trans %}qs_community.dashboard.waiting_approval{% endtrans %}
          </a>
        </li>
      </ul>
    </div>
  </div>
</div>

