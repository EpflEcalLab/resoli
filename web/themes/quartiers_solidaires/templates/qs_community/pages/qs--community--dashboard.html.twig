{% extends "@quartiers_solidaires/wrapper/modal.html.twig" %}

{% import "@quartiers_solidaires/macros.html.twig" as macros %}

{% set modal_bg = 'danger' %}
{% set modal_title = 'qs.auth.communities.dashboard_title @variables.community.name.value'|t({
  '@variables.community.name.value': variables.community.name.value,
})%}
{% set modal_subtitle = 'qs.auth.communities.dashboard_description'|t %}
{% set floating_buttons = [
  {
    label: 'qs_menu.links.account.communities'|t,
    icon: 'communities-sm',
    active: true,
  }
] %}

{% block modal_content %}
  {% set btn_default_classes = 'btn-outline-danger btn-outline-invert' %}
  {% set params = {community: variables.community.tid.value} %}
  {% set buttons = {
    'Community members': {
      label: 'qs_community.dashboard.members'|t,
      icon: 'happy',
      path: 'qs_community.members',
    },
    'Community membery waiting approval': {
      label: 'qs_community.dashboard.waiting_approval'|t,
      icon: 'wait',
      path: 'qs_community.members',
    },
    'Community events export': {
      label: 'qs_community.events.export.download'|t,
      icon: 'download',
      path: 'qs_community.events.export',
    },
  } %}

  {{ macros.list_buttons(buttons, btn_default_classes, params) }}
{% endblock %}



