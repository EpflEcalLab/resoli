
{% if bamboo_has_role('authenticated') %}
  <a href="{{ path('user.logout') }}">{% trans %}qs_auth.logout{% endtrans %}
  <a href="{{ path('qs_auth.communities') }}">{% trans %}qs_auth.communities{% endtrans %}
{% else %}
  <a href="{{ path('qs_auth.login') }}">{% trans %}qs_auth.login{% endtrans %}
  <a href="{{ path('qs_auth.register') }}">{% trans %}qs_auth.register{% endtrans %}
{% endif %}
