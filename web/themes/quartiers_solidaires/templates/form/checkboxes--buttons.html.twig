{#
/**
 * @file
 * Theme override for a 'checkboxes' #type form element.
 *
 * Available variables
 * - attributes: A list of HTML attributes for the wrapper element.
 * - children: The rendered checkboxes.
 *
 * @see template_preprocess_checkboxes()
 */
#}

{%
  set classes = [
  'font-weight-bold',
  ]
%}
{% if attributes.title is not empty or required -%}
<div>
  <label{{ attributes.addClass(classes) }}>{{ attributes.title|raw }}</label> {%- if required or attributes.required -%} * {%- endif -%}
</div>
{% endif %}
<div{{ attributes.addClass('js-filter-themes btn-grid mb-5') }} data-toggle="buttons">{{ children }}</div>
