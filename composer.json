{
    "name": "drupal/quartiers-solidaires",
    "description": "Resoli Drupal project",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Antistatique SA",
            "role": "Development Agency"
        },
        {
            "name": "Kevin Wenger",
            "role": "FullStack Developer at Antistatique SA"
        },
        {
            "name": "Toni Fisler",
            "role": "Frontend Developer at Antistatique SA"
        }
    ],
    "homepage": "https://www.resoli.ch",
    "support": {
        "docs": "https://github.com/antistatique/quartiers-solidaires"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "php": ">=8.0",
        "composer/installers": "^1.12",
        "cweagans/composer-patches": "^1.7.2",
        "dompdf/dompdf": "^2.0.0",
        "drupal/admin_toolbar": "^3.1.1",
        "drupal/allowed_formats": "^1.5",
        "drupal/backerymails": "^2.1",
        "drupal/bamboo_twig": "^5.0",
        "drupal/console": "^1.9.8",
        "drupal/core-composer-scaffold": "^9.4.5",
        "drupal/core-project-message": "^9.4.5",
        "drupal/core-recommended": "^9.4.5",
        "drupal/field_group": "^3.2",
        "drupal/focal_point": "^1.5@beta",
        "drupal/gin": "^3.0",
        "drupal/honeypot": "^2.1.1",
        "drupal/image_effects": "^3.3",
        "drupal/jquery_ui_datepicker": "^1.3",
        "drupal/loco_translate": "^2.1",
        "drupal/mailsystem": "^4.4",
        "drupal/masquerade": "^2.0@beta",
        "drupal/metatag": "^1.21",
        "drupal/new_relic_rpm": "^2.1",
        "drupal/pathauto": "^1.11",
        "drupal/recaptcha": "^3.0",
        "drupal/redirect": "^1.7@beta",
        "drupal/swiftmailer": "^2.2",
        "drush/drush": "^10.6.2",
        "mglaman/phpstan-drupal": "^0.12.15",
        "phpoffice/phpspreadsheet": "^1.24.1",
        "symfony/property-access": "^3.4.47",
        "webflo/drupal-finder": "^1.2.2",
        "webmozart/path-util": "^2.3",
        "xantios/mimey": "^2.2"
    },
    "require-dev": {
        "alexandresalome/mailcatcher": "^1.4",
        "behat/behat": "^3.11",
        "drupal/core-dev": "^9.4.5",
        "drupal/default_content": "^1.0@alpha",
        "drupal/drupal-extension": "^4.2.1",
        "drupal/rules": "^3.0@alpha",
        "drupal/schema_metatag": "^1.8",
        "drupol/phpcsfixer-configs-drupal": "^2.0.1",
        "friendsofphp/php-cs-fixer": "^3.4",
        "phpmd/phpmd": "^2.12",
        "phpspec/prophecy-phpunit": "^2.0",
        "phpunit/phpunit": "^9.5",
        "wapmorgan/php-code-fixer": "^2.0.29"
    },
    "conflict": {
        "drupal/drupal": "*",
        "drupal/ctools": "4.0.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
      "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/console-extend-plugin": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true
        }
    },
    "autoload-dev": {
      "psr-4": {
          "Drupal\\Behat\\": "behat"
      }
    },
    "extra": {
        "drupal-scaffold": {
            "initial": {
                ".editorconfig": "../.editorconfig",
                ".gitattributes": "../.gitattributes"
            },
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/{$name}": ["type:drupal-drush"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"]
        },
        "enable-patching": true,
        "patches": {
        }
    }
}
