<div class="fullpage-wrapper py-4">
  <div class="container">
    <div class="d-flex justify-content-between mb-3">
      {% block fullpage_back_buttons %}{% endblock %}
    </div>
  </div>

  <div class="container my-auto">
    {% block fullpage_content_wrapper %}
      <div class="row">
        <div class="col-sm-10 col-lg-8 mx-auto text-center">
          {% block fullpage_content %}{% endblock %}
        </div>
      </div>
    {% endblock %}
  </div>
</div>
