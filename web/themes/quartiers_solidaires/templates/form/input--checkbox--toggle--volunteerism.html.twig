{% import '@quartiers_solidaires/macros.html.twig' as macros %}
{#
/**
 * @file
 * Theme override for an 'input' #type form element.
 *
 * Available variables:
 * - attributes: A list of HTML attributes for the input element.
 * - children: Optional additional rendered elements.
 *
 * @see template_preprocess_input()
 */
#}

<div class="form-group checkbox-toggle-container row col-md-10 mx-auto">
  <div class="col-8 d-flex items-center">
    <div class="icon-circle btn-outline-invert shadow-to-right btn-outline-primary my-auto mr-4">
    {{ macros.icon('theme_' ~ element['#icon'], ['icon']) }}
    </div>
    <div class="my-auto">
      <label class="font-weight-bold mb-0" for="{{ attributes.id }}">{{ element['#title'] }}</label>
      <p class="mb-0">{{ element['#body'] }}</p>
    </div>
  </div>
  <div class="col-4 d-flex justify-content-end">
    <input{{ attributes.addClass('checkbox-toggle') }} />
    <label tabindex="0" for="{{ attributes.id }}" class="checkbox-toggle-btn"></label>
  </div>
</div>

