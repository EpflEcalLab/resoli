<div class="col-sm-6 mb-3 mx-auto">
  {# Register Button "subscription pending" #}
  <button data-status-show="pending" class="btn btn-outline-info btn-white btn-icon shadow-to-right btn-block" type="submit" value="{{ 'qs.event.register.pending'|t }}">
    {{ macros.icon('wait') }}
    {{ 'qs.event.register.pending'|t }}
  </button>

  {# Register Button "subscription confirmed" #}
  <button data-status-show="confirmed" class="btn btn-info btn-icon shadow-to-bottom btn-block mt-0" type="submit" value="{{ 'qs.event.register.confirmed'|t }}">
    {{ macros.icon('checkflag') }}
    {{ 'qs.event.register.confirmed'|t }}
  </button>

  {# Register button default #}
  {{ qs_site_render_form('qs_subscription', 'RequestForm', {'event': event.nid.value}, 'qs_subscription_request_form_'~event.nid.value) }}
</div>
