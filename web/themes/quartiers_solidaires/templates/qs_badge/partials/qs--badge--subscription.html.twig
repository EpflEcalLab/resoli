
{# Subscription Badges #}
{% if event.nid.value and badges.subscriptions %}
  {# Subscription pendings badge #}
  {% if event.nid.value in badges.subscriptions.pendings|keys %}
    {{ macros.badge('info', 'wait', 'flag-subscription-wait') }}
  {% endif %}

  {# Subscription confirmed badge #}
  {% if event.nid.value in badges.subscriptions.confirmed|keys %}
    {{ macros.badge('info', 'confirmed', 'flag-subscription-confirmed') }}
  {% endif %}
{% endif %}
