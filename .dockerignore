# Ignore git
.git*

# Ignore docker fikes
.dockerignore
docker-compose.*
Dockerfile

# Ignore backup stuff
backups

# Ignore directories & files generated by Styleguide
node_modules
.sass-cache
.publish
.bundle
.env
npm-debug.log
dist
build
styleguide
web/themes/*/build
web/themes/*/node_modules

# Ignore directories generated by Composer
drush/contrib/
vendor/
web/core/
web/modules/contrib/
web/themes/contrib/
web/profiles/contrib/
web/libraries/

# Ignore sensitive information
*.sql

# Ignore Drupal's file directory
web/sites/*/files/
