{% extends "@quartiers_solidaires/modals/modal.html.twig" %}
{% import "@quartiers_solidaires/macros.html.twig" as macros %}

{% set modal_bg = 'secondary' %}
{% set modal_title = 'qs.event.dashboard_title @event'|t({
  '@event': variables.event.title.value
}) %}
{% set modal_subtitle = 'qs.event.dashboard_description'|t %}
{% set floating_buttons = [
  {
    label: 'qs_activity.floating.dashboard.event'|t,
    icon: 'activities',
    active: true,
  }
] %}

{% block modal_content %}

  {% set btn_default_classes = 'btn-outline-invert' %}
  {% set params = {'event': variables.event.id} %}
  {% set buttons = {
    'Edit event button': {
      label: 'qs.event.edit'|t,
      path: 'qs_activity.events.form.edit',
    },
    'Subscribers button': {
      label: 'qs.event.subscriptions.subscribers'|t,
      path: 'qs_subscription.subscribers',
      icon: 'register',
    },
    'Subscribers waiting approval button': {
      label: 'qs.event.subscriptions.waiting_approval'|t,
      path: 'qs_subscription.waiting_approval',
      icon: 'wait',
    },
    'Delete button': {
      label: 'qs.event.delete'|t,
      path: 'qs_activity.events.form.delete',
      icon: 'trash',
      list_classes: 'mt-5',
      classes: 'btn-danger',
    },
  } %}
  {{ macros.list_buttons(buttons, btn_default_classes, params) }}
{% endblock %}

