{
    "name": "drupal/quartiers-solidaires",
    "description": "Resoli Drupal project",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Antistatique SA",
            "role": "Development Agency"
        },
        {
            "name": "Kevin Wenger",
            "role": "FullStack Developer at Antistatique SA"
        },
        {
            "name": "Toni Fisler",
            "role": "Frontend Developer at Antistatique SA"
        }
    ],
    "homepage": "https://www.resoli.ch",
    "support": {
        "docs": "https://github.com/antistatique/quartiers-solidaires"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "php": ">=8.1 || >= 8.2",
        "composer/installers": "^2.2",
        "cweagans/composer-patches": "^1.7.3",
        "dompdf/dompdf": "^2.0.1",
        "drupal/admin_toolbar": "^3.3",
        "drupal/allowed_formats": "^3.0",
        "drupal/backerymails": "^3.0",
        "drupal/bamboo_twig": "^6.0",
        "drupal/ckeditor": "^1.0",
        "drupal/core-composer-scaffold": "^10.4",
        "drupal/core-project-message": "^10.4",
        "drupal/core-recommended": "^10.4",
        "drupal/field_group": "^3.4",
        "drupal/focal_point": "^2.0",
        "drupal/gin": "^4.0",
        "drupal/gin_toolbar": "^2.0",
        "drupal/honeypot": "^2.1.2",
        "drupal/image_effects": "^4.0",
        "drupal/jquery_ui_datepicker": "^2.0",
        "drupal/jquery_ui_draggable": "^2.0",
        "drupal/loco_translate": "^3.0",
        "drupal/mailsystem": "^4.4",
        "drupal/masquerade": "^2.0",
        "drupal/metatag": "^2.0",
        "drupal/pathauto": "^1.11",
        "drupal/recaptcha": "^3.1",
        "drupal/redirect": "^1.8@beta",
        "drupal/symfony_mailer_lite": "^2.0",
        "drush/drush": "^13.3",
        "phpoffice/phpspreadsheet": "^1.26",
        "symfony/property-access": "^6.4",
        "webflo/drupal-finder": "^1.2.2",
        "xantios/mimey": "^2.2"
    },
    "require-dev": {
        "alexandresalome/mailcatcher": "^1.4",
        "behat/behat": "^3.12",
        "drupal/core-dev": "^10.4",
        "drupal/default_content": "^2.0@alpha",
        "drupal/drupal-extension": "^5.0",
        "drupal/rules": "^4.0",
        "drupal/schema_metatag": "^3.0",
        "drupal/upgrade_status": "^4.1",
        "mglaman/phpstan-drupal": "^1.1",
        "phpspec/prophecy-phpunit": "^2.0.1",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpunit/phpunit": "^9.5.27"
    },
    "conflict": {
        "drupal/drupal": "*",
        "drupal/ctools": "4.0.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
      "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/console-extend-plugin": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "autoload-dev": {
      "psr-4": {
          "Drupal\\Behat\\": "behat"
      }
    },
    "extra": {
        "drupal-scaffold": {
            "initial": {
                ".editorconfig": "../.editorconfig",
                ".gitattributes": "../.gitattributes"
            },
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/{$name}": ["type:drupal-drush"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"]
        },
        "enable-patching": true,
        "patches": {
        }
    }
}
