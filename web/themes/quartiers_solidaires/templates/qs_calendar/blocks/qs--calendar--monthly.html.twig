{% extends "@quartiers_solidaires/qs_calendar/blocks/qs--calendar--weekly.html.twig" %}

{% set base_id = 'calendar-monthly' %}
{% set prev = variables.prev_month %}
{% set next = variables.next_month %}
{% set compare = 'Y-m' %}
{% set aria_label = true %}

{% block previous_btn %}
  <span class="d-none d-sm-inline">{{ prev|bamboo_i18n_format_date('custom', 'F') }}</span>
{% endblock %}

{% block next_btn %}
  <span class="d-none d-sm-inline">{{ variables.next_month|bamboo_i18n_format_date('custom', 'F') }}</span>
{% endblock %}

{% block calendar_dates %}
  {% for day in variables.dates %}
    {% set is_today = day|date('Y-m-d') == 'now'|date('Y-m-d') %}
    {% set is_current_month = day|date('Y-m') == variables.current_day|date('Y-m') %}
    {% set is_active = day|date('Y-m-d') == variables.current_day|date('Y-m-d') %}
    {% set is_past = day|date('Y-m-d') < 'now'|date('Y-m-d') %}

    {% set classes = [
      'calendar-item btn btn-circle shadow-to-bottom',
      is_today ? 'btn-outline-secondary' : 'btn-outline-primary',
      is_active ? 'active',
      not is_today and (is_past or day|date('Y-m-d') not in variables.events|keys) ? 'disabled',
    ] %}

    {% set parameters = is_today ? {} : {'day': day|date('Y-m-d')} %}

    {% block calendar_dot %}
      {% if is_current_month %}
        {{ parent() }}
      {% else %}
        <span class="{{ classes|join(' ') }} disabled"></span>
      {% endif %}
    {% endblock %}

  {% endfor %}
{% endblock %}
