    ->accessCheck();

  $query = $privilegeQuery->condition('user', $entity->id());

  $ids = $query->execute();

  if ($ids) {
    $privileges = $privilegeStorage->loadMultiple($ids);
    $privilegeStorage->delete($privileges);
  }
}
