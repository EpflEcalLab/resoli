{% import "@quartiers_solidaires/macros.html.twig" as macros %}

<div class="container">
  <div class="row">
    <div class="col-sm-10 col-lg-8 mx-auto text-center">
      <h2>{{ 'qs.auth.communities.dashboard_title'|t }}</h2>
      <p>{{ 'qs.auth.communities.dashboard_description'|t }}</p>
    </div>
  </div>
  <div class="row">
    <div class="col-sm-8 col-md-6 mx-auto">
      <ul class="list-unstyled mt-3">
        <li>
          <a class="btn btn-outline-secondary btn-icon btn-block shadow-to-bottom mb-2" href="{{ path('qs_activity.events.form.edit', {'event': variables.event.id}) }}">
            {{ macros.icon('pencil') }}
            {{ 'qs.event.edit'|t }}
          </a>
        </li>
        <li>
          <a class="btn btn-outline-secondary btn-icon btn-block shadow-to-bottom mb-2" href="javascript:alert('This feature is not yet availaible.')">
            {{ 'qs.event.subscriptions'|t }}
          </a>
        </li>
        <li>
          <a class="btn btn-outline-danger btn-icon btn-block shadow-to-bottom mb-2" href="javascript:alert('This feature is not yet availaible.')">
            {{ macros.icon('trash') }}
            {{ 'qs.event.delete'|t }}
          </a>
        </li>
      </ul>
    </div>
  </div>
</div>
