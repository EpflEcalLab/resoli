<form{{ attributes.addClass(classes) }}>
  <div class="modal-body">
    {% if attributes.title %}
      <h1 class="text-center mt-3 mb-5">{{ attributes.title }}</h1>
    {% endif %}
    {% if attributes.description %}
      <p class="text-center mb-5">{{ attributes.description }}</p>
    {% endif %}
    {{ children }}
  </div>
</form>
