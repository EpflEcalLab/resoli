{% extends "@quartiers_solidaires/wrapper/modal.html.twig" %}
{% import "@quartiers_solidaires/macros.html.twig" as macros %}

{% set modal_bg = 'primary' %}

{% set modal_title = variables.activity.title.value %}
{% set modal_title_icon = 'theme_' ~ variables.activity.field_theme.entity.field_icon.value ~ '_lg' %}

{% set floating_buttons = [
  {
    label: 'qs_activity.floating.dashboard.activity'|t,
    icon: 'activities',
    active: true,
  }
] %}

{% block modal_content %}

  {% set btn_default_classes = 'btn-outline-invert' %}
  {% set params = {'activity': variables.activity.id} %}
  {% set buttons = {
    'Edit info Button': {
      label: 'qs.activity.edit_info'|t,
      path: 'qs_activity.activities.form.edit.info',
    },
    'Edit visibility Button': {
      label: 'qs.activity.edit_visibility'|t,
      path: 'qs_activity.activities.form.edit.visibility',
    },
    'Edit default values Button': {
      label: 'qs.activity.edit_default_values'|t,
      path: 'qs_activity.activities.form.edit.defaults',
    },
    'Manage members Button': {
      label: 'qs.activity.members'|t,
      path: 'qs_activity.activities.members',
      icon: 'happy',
    },
    'Add event Button': {
      label: 'qs.activity.add_event'|t,
      path: 'qs_activity.events.form.add',
      icon: 'plus',
      classes: 'btn-secondary',
      list_classes: 'mt-5'
    },
    'Delete Button': {
      label: 'qs.activity.delete'|t,
      path: 'qs_activity.activities.form.delete',
      icon: 'trash',
      classes: 'btn-danger',
      list_classes: 'mt-5'
    },
  } %}
  {{ macros.list_buttons(buttons, btn_default_classes, params) }}

{% endblock %}
