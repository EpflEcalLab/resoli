/**
 * Hook User Entity Delete.
 *
 * Remove privilges of this User when deleted.
 *
 * Implements hook_ENTITY_TYPE_delete().
 */
function qs_acl_user_delete(EntityInterface $entity) {
  /** @var \Drupal\Core\Entity\EntityTypeManagerInterface */
