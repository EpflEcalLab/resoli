<?php

/**
 * @file
 * QS Subscription hooks.
 */

use Drupal\Core\Entity\EntityInterface;

// Includes.
require_once 'inc/mails.inc';

/**
 * Implements hook_theme().
 */
function qs_subscription_theme() {
  return [
    'qs_subscription_subscribers_page' => [
      'variables' => ['variables' => []],
      'template' => 'qs--subscription--subscribers',
    ],
    'qs_subscription_waiting_approval_page' => [
      'variables' => ['variables' => []],
      'template' => 'qs--subscription--waiting-approval',
    ],
    'qs_subscription_user_collection_page' => [
      'variables' => ['variables' => []],
      'template' => 'qs--subscription--user-collection',
    ],
  ];
}

/**
 * Hook Event Entity Delete.
 *
 * Remove subscription of this Event to any user when deleted.
 *
 * Implements hook_ENTITY_TYPE_delete().
 */
function qs_subscription_node_delete(EntityInterface $entity) {
  /** @var \Drupal\Core\Entity\EntityTypeManagerInterface */
  $entityTypeManager = Drupal::service('entity_type.manager');
  /** @var \Drupal\Core\Entity\ContentEntityStorageInterface */
  $subscriptionStorage = $entityTypeManager->getStorage('subscription');
  /** @var \Drupal\Core\Entity\Query\QueryInterface */
  $subscriptionQuery = $subscriptionStorage->getQuery()
    ->accessCheck();

  $query = $subscriptionQuery->condition('entity', $entity->id());

  $ids = $query->execute();

  if ($ids) {
    $subscriptions = $subscriptionStorage->loadMultiple($ids);
    $subscriptionStorage->delete($subscriptions);
  }
}

/**
 * Hook User Entity Delete.
 *
 * Remove subscription of this User when deleted.
 *
 * Implements hook_ENTITY_TYPE_delete().
 */
function qs_subscription_user_delete(EntityInterface $entity) {
  /** @var \Drupal\Core\Entity\EntityTypeManagerInterface */
  $entityTypeManager = Drupal::service('entity_type.manager');
  /** @var \Drupal\Core\Entity\ContentEntityStorageInterface */
  $subscriptionStorage = $entityTypeManager->getStorage('subscription');
  /** @var \Drupal\Core\Entity\Query\QueryInterface */
  $subscriptionQuery = $subscriptionStorage->getQuery()
    ->accessCheck();

  $query = $subscriptionQuery->condition('user', $entity->id());

  $ids = $query->execute();

  if ($ids) {
    $subscriptions = $subscriptionStorage->loadMultiple($ids);
    $subscriptionStorage->delete($subscriptions);
  }
}
