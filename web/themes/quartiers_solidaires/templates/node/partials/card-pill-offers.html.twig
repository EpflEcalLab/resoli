{% import "@quartiers_solidaires/macros.html.twig" as macros %}

<a
  data-toggle="collapse"
  href="#collapse-{{ key }}"
  class="card-pill {{ not is_open ? "collapsed" }}"
  role="tab"
  aria-expanded="{{ is_open ? "true" : "false" }}"
  aria-controls="collapse-{{ key }}"
  id="offer{{ offer.nid.value }}"
>
  <span class="card-pill-icon">
    {{ macros.icon('user') }}
  </span>

  <span class="card-pill-title">
    {{ offer.field_contact_name.value }}
  </span>

  <span
    class="btn btn-outline-info btn-icon btn-icon-to-circle shadow-to-bottom btn-white ml-auto"
    aria-label="{{ 'qs.readmore.about'|t }} {{ offer.label }}"
  >
    {{ macros.icon('look') }}
    <span class="d-none d-sm-inline">
      {{ 'qs.event.readmore'|t }}
      <span class="sr-only">{{ 'qs.event.readmore.about'|t }} {{ offer.label }}</span>
    </span>
  </span>

</a>
