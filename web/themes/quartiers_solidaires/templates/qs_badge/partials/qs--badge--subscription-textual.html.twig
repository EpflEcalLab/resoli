{# Subscription Textual Badges #}
{% if event.nid.value and badges.subscriptions %}

  {% set user_subscription_confirmed = event.nid.value in badges.subscriptions.confirmed|keys %}

  {% set user_subscription_pending = event.nid.value in badges.subscriptions.pendings|keys %}

  {% set guest_subscription_pending = event.nid.value in badges.subscriptions.pendings_guests|keys %}

  {% set guest_subscription_confirmed = event.nid.value in badges.subscriptions.confirmed_guests|keys %}

  {# Adapte the color of text according user privilege of activity #}
  {% if badges.privileges %}
    {# Get user Highest privilege #}
    {% set privilege = badges.privileges[event.field_activity.entity.nid.value]|last %}

    {% set theme = [
      'd-block',
      privilege == 'activity_maintainers' ? 'text-warning',
      privilege == 'activity_organizers' ? 'text-danger',
    ] %}
  {% endif %}

  {# Show own user subscription state, alwayse #}
  <p class="text-info">
    <strong>
      {% if user_subscription_pending %}
        <strong class="{{ theme|join(' ') }}">{{ 'qs.event.user.subscription.pending'|t }}</strong>
      {% endif %}

      {% if user_subscription_confirmed %}
        <strong class="{{ theme|join(' ') }}">{{ 'qs.event.user.subscription.confirmed'|t }}</strong>
      {% endif %}
    </strong>

  {% if badges.privileges %}
    {# If user is (activity_maintainers and confirmed) or activity_organizers of this event #}
    {# show him number of pending guests #}
    {% if (privilege == 'activity_maintainers' and user_subscription_confirmed) or privilege == 'activity_organizers' %}
      {# Pending Guests subscriptions Badge #}
      {% if guest_subscription_pending %}
        {% set attendees = badges.subscriptions.pendings_guests[event.nid.value] %}
        <strong class="{{ theme|join(' ') }}">{{ 'qs.event.user.subscription.pendings_guests @count'|t({'@count': attendees}) }}</strong>
      {% endif %}
    {% endif %}
  {% endif %}

  {# Confirmed Guests subscriptions Badge #}
  {% if guest_subscription_confirmed and not guest_subscription_pending %}
    {% set attendees = badges.subscriptions.confirmed_guests[event.nid.value] %}
    <strong class="{{ theme|join(' ') }}">{{ 'qs.event.user.subscription.confirmed_guests @count'|t({'@count': attendees}) }}</strong>
  {% endif %}
  </p>

{% endif %}
