{
    "name": "drupal/quartiers-solidaires",
    "description": "Resoli Drupal project",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Antistatique SA",
            "role": "Development Agency"
        },
        {
            "name": "Kevin Wenger",
            "role": "FullStack Developer at Antistatique SA"
        },
        {
            "name": "Toni Fisler",
            "role": "Frontend Developer at Antistatique SA"
        }
    ],
    "homepage": "https://www.resoli.ch",
    "support": {
        "docs": "https://github.com/antistatique/quartiers-solidaires"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^1.7",
        "cweagans/composer-patches": "^1.6",
        "dompdf/dompdf": "^1.0",
        "drupal/admin_toolbar": "^3.0",
        "drupal/allowed_formats": "^1.1",
        "drupal/backerymails": "^2.0",
        "drupal/bamboo_twig": "^5.0",
        "drupal/console": "^1.0.2",
        "drupal/core-composer-scaffold": "^9.0.0",
        "drupal/core-project-message": "^9.0.0",
        "drupal/core-recommended": "^9.0.0",
        "drupal/field_group": "^3.0",
        "drupal/focal_point": "^1.0@beta",
        "drupal/gin": "^3.0",
        "drupal/honeypot": "^2.0",
        "drupal/image_effects": "^3.0",
        "drupal/jquery_ui_datepicker": "^1.1",
        "drupal/loco_translate": "^2.0",
        "drupal/mailsystem": "^4.1",
        "drupal/masquerade": "^2.0@beta",
        "drupal/metatag": "^1.1",
        "drupal/new_relic_rpm": "^2.1",
        "drupal/pathauto": "^1.0",
        "drupal/recaptcha": "^3.0",
        "drupal/redirect": "^1.0@beta",
        "drupal/swiftmailer": "^2.0",
        "drush/drush": "^10.0.0",
        "egulias/email-validator": "^2.1.11",
        "mglaman/phpstan-drupal": "^0.12.12",
        "phpoffice/phpspreadsheet": "^1.7",
        "ralouphie/mimey": "^2.0",
        "symfony/property-access": "^3.3",
        "webflo/drupal-finder": "^1.0.0",
        "webmozart/path-util": "^2.3"
    },
    "require-dev": {
        "alexandresalome/mailcatcher": "^1.2",
        "behat/behat": "^3.5.0",
        "drupal/core-dev": "^9.0.0",
        "drupal/default_content": "^1.0@alpha",
        "drupal/drupal-extension": "^4.1",
        "drupal/schema_metatag": "^1.3",
        "drupol/phpcsfixer-configs-drupal": "^2",
        "friendsofphp/php-cs-fixer": "^3",
        "phpmd/phpmd": "^2.6",
        "sebastian/phpcpd": "^4.1.0",
        "wapmorgan/php-code-fixer": "^2.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
      "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/console-extend-plugin": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true
        }
    },
    "autoload-dev": {
      "psr-4": {
          "Drupal\\Behat\\": "behat"
      }
    },
    "extra": {
        "drupal-scaffold": {
            "initial": {
                ".editorconfig": "../.editorconfig",
                ".gitattributes": "../.gitattributes"
            },
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/{$name}": ["type:drupal-drush"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"]
        },
        "enable-patching": true,
        "patches": {
            "drupal/captcha": {
                "[3211466] - Testing modules property Access Level": "https://www.drupal.org/files/issues/2021-04-29/captcha-module-property-access-level.patch"
            }
        }
    }
}
