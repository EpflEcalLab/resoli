<div class="navbar-container">
  <button class="btn btn-outline-primary navbar-toggle navbar-toggle-simple" title="Afficher ou cacher le menu">
    {% include "@atoms/icon/icon.twig" with {icon: 'wheel'} %}
  </button>
  <nav class="navbar">
    {% for key, value in nav_items %}
    <a href="#" class="nav-item{{ loop.index == 2 ? ' active' }}">
      {% include "@atoms/icon/icon.twig" with {icon: key ~ '-big'} %}
      {{value}}
    </a> {% endfor %}
  </nav>
  <div class="navbar-overlay"></div>
</div>
