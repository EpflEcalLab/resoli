<form action="#" class="form-multistep" id="form1">
  <div class="tab-content">
    <fieldset data-step="Step 1" class="tab-pane fade" id="step1">
      <div class="form-group">
        <label class="form-control-label" for="formGroupExampleInput">First label</label>
        <input required type="text" class="form-control" id="formGroupExampleInput" placeholder="Example input">
      </div>
    </fieldset>
    <fieldset data-step="Step 2" class="tab-pane fade" id="step2">
      <div class="form-group">
        <label class="form-control-label" for="formGroupExampleInput2">Second label</label>
        <input type="text" class="form-control" id="formGroupExampleInput2" placeholder="Example input">
      </div>
      <div class="form-group">
        <label class="form-control-label" for="formGroupExampleInput3">Second label</label>
        <input type="text" class="form-control" id="formGroupExampleInput3" placeholder="Example input">
      </div>
    </fieldset>
    <fieldset data-step="Step 3" class="tab-pane fade" id="step3">
      <div class="form-group">
        <label class="form-control-label" for="formGroupExampleInput4">Third label</label>
        <input type="text" class="form-control" id="formGroupExampleInput4" placeholder="Example input">
      </div>
    </fieldset>
    <input type="submit" name="submit" value="Submit" class="button btn btn-primary">
  </div>
</form>
