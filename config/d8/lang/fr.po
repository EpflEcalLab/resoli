msgstr "Accès refusé à la communauté @community sur @sitename!"

msgid "qs.mail.community.waiting_approval.decline.body @mail @firstname @lastname @community @url"
msgstr ""
"Bonjour @firstname @lastname,\n"
"\n"
"nous avons le regret de vous informer qu’une des personnes responsables de la communauté @community a refusé votre demande d’inscription.\n"
"\n"
"Si désiré, vous pouvez à nouveau vous connecter à l’adresse @url en utilisant votre adresse e-mail @mail et faire une nouvelle demande d’inscription à une autre communauté.\n"
"\n"
"Cordialement,\n"
"l’équipe Réseaux Solidaires"

msgid "qs.mail.community.waiting_approval.confirm.subject @sitename @mail @firstname @lastname @community"
msgstr "Accès validé à la communauté @community sur @sitename!"

msgid "qs.mail.community.waiting_approval.confirm.body @mail @firstname @lastname @community @url"
msgstr ""
"Bonjour @firstname @lastname,\n"
"\n"
"nous avons le plaisir de vous informer qu’une des personnes responsables de la communauté @community a validé votre demande d’inscription.\n"
"\n"
"Vous pouvez dès à présent vous y connecter à l’adresse @url en utilisant votre adresse e-mail @mail.\n"
"\n"
"Cordialement,\n"
"l’équipe Réseaux Solidaires"

msgid "qs.previous.to_community_welcome"
msgstr "Retour à l’accueil"

