{% import "@quartiers_solidaires/macros.html.twig" as macros %}

<a
  data-toggle="collapse"
  href="#collapse-{{ key }}"
  class="card-pill {{ not is_open ? "collapsed" }}"
  role="tab"
  aria-expanded="{{ is_open ? "true" : "false" }}"
  aria-controls="collapse-{{ key }}"
  id="request{{ request.nid.value }}"
>
  <span class="card-pill-icon">
    {{ macros.icon('theme_' ~ request.field_theme.entity.field_sharing_icon.value) }}
  </span>

  <span class="card-pill-title mr-auto">
    <span>{{ request.field_theme.entity.name.value }}</span>
  </span>

  <span class="card-pill-title {% if is_solved %}card-pill-deactivated{% endif %} mx-auto">
    {% if is_solved %}
      {{ 'qs_sharing.collection.request.solved @date'|t({
        '@date': request.field_solved_at.date|bamboo_i18n_format_date('default_medium_date_only')
      }) }}
    {% else %}
      <time datetime="{{ request.changed.date|date('Y-m-d') }}">
        {{ request.changed.date|bamboo_i18n_format_date('default_medium_date_only') }}
      </time>
    {% endif %}
  </span>

  <span
    class="btn btn-icon btn-icon-to-circle shadow-to-bottom ml-auto"
    aria-label="{{ 'qs.readmore.about'|t }} {{ request.label }}"
  >
    {{ macros.icon('look') }}
    <span class="d-none d-sm-inline">
      {{ 'qs_sharing.collection.request.readmore'|t }}
      <span class="sr-only">{{ 'qs_sharing.collection.request.readmore.about'|t }} {{ request.label }}</span>
    </span>
  </span>

</a>
