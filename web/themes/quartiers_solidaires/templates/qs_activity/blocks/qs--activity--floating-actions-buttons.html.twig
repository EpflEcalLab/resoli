{% if variables.buttons is not empty %}
  {% import "@quartiers_solidaires/macros.html.twig" as macros %}
  <div class="floating">
    <div class="container">
      <div class="d-flex justify-content-center">
        {% for button in variables.buttons %}
          <a
            class="btn btn-white {{ button.icon ? 'btn-icon' }} btn-outline-{{ button.theme }} shadow-floating mb-3 mx-2 {{ button.classes|join(' ') }}"
            href="{{ button.url }}">
            {% if button.icon %}{{ macros.icon(button.icon) }}{% endif %}
            {{ button.label }}
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}
