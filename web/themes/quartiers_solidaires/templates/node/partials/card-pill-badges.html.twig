{% import '@quartiers_solidaires/macros.html.twig' as macros %}

{% set privilege = privileges[event.field_activity.entity.nid.value]|last %}
{% set theme = 'info' %}
{% if privilege == 'activity_maintainers' %}
  {% set theme = 'warning' %}
  {% set shield = true %}
{% endif %}
{% if privilege == 'activity_organizers' %}
  {% set theme = 'danger' %}
  {% set shield = true %}
{% endif %}

{{ macros.badge(theme, 'wait', 'flag-subscription-wait', 'qs.event.user.subscription.pending'|t, shield, 'pending') }}
{{ macros.badge(theme, 'confirmed', 'flag-subscription-confirmed', 'qs.event.user.subscription.confirmed'|t, shield, 'confirmed') }}

{# Pending Guests subscriptions Badge #}
{{ macros.badge('outline-' ~ theme, 'wait', 'flag-subscription-guests-wait', 'qs.event.user.subscription.pendings_guests'|t, shield, 'pendings_guests') }}

{# Confirmed Guests subscriptions Badge #}
{{ macros.badge('outline-' ~ theme, 'confirmed', 'flag-subscription-guests-confirmed', 'qs.event.user.subscription.confirmed_guests'|t, shield, 'confirmed_guests') }}
